<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AnotadorGymApp.PopUp.BuscarEjerciciosPopUp"               
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit" Padding="0" BackgroundColor="{DynamicResource CardBackground}">

    <Grid Margin="0" Padding="0" WidthRequest="350" BackgroundColor="{DynamicResource CardBackground}" RowSpacing="10" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" MaximumHeightRequest="500">
        <Border Style="{DynamicResource BorderWithShadowStyle}" Grid.Row="0">
            <Entry x:Name="EjerciciosSearchBar"
                    Placeholder="Buscar Ejercicio..."
                    TextChanged="EjerciciosSearchBar_TextChanged"
                    TextColor="{DynamicResource PrimaryTextColor}"
                    PlaceholderColor="{DynamicResource DisabledTextColor}"
                    FontSize="14" BackgroundColor="Transparent" Margin="0"/>

        </Border>

        <Label Text="Resultados:"
       Grid.Row="1"
       FontSize="12"
       Margin="5,0"
       TextColor="{DynamicResource SecondaryTextColor}" />

        <CollectionView x:Name="FiltradosCollectionView" ItemsSource="{Binding FiltradosEjercicios}" Grid.Row="2"
                        SelectionChanged="FiltradosCollectionView_SelectionChanged" SelectionMode="Single">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout ItemSpacing="10" Orientation="Vertical"></LinearItemsLayout>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid BackgroundColor="Transparent" Padding="0" RowDefinitions="*,*">
                        <Label Text="{Binding Nombre}" Style="{DynamicResource SubHeadline}" FontSize="12"></Label>
                        <BoxView HeightRequest="1" Grid.Row="1" VerticalOptions="End" BackgroundColor="{DynamicResource DividerColor}"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Text="Ejercicios seleccionados"
       Grid.Row="3"
       FontSize="12"
       Margin="5,0"
       TextColor="{DynamicResource SecondaryTextColor}" />

        <CollectionView x:Name="SeleccionadosCollectionView" Margin="0" Grid.Row="4" BackgroundColor="Transparent">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout ItemSpacing="0" Orientation="Vertical"></LinearItemsLayout>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid IsClippedToBounds="False" Padding="6">
                        <Border Style="{DynamicResource BorderWithShadowStyle}" Margin="0" Padding="0">
                            <Grid ColumnSpacing="10" ColumnDefinitions="*,Auto" Padding="7">
                                <Label Text="{Binding Nombre}" Style="{DynamicResource SubHeadline}" FontSize="10" VerticalOptions="Center" MaxLines="3" Grid.Column="0"></Label>
                                <Button Text="✕" HorizontalOptions="End" Padding="0" VerticalOptions="Center" HeightRequest="24" WidthRequest="24" Grid.Column="1"
                                            Clicked="BorrarEjercicio_Clicked" CornerRadius="13" BackgroundColor="{DynamicResource CardBackground}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <HorizontalStackLayout Spacing="10" Padding="0" HorizontalOptions="Center" Grid.Row="5" VerticalOptions="End" Margin="0,0,0,10">
            <Button x:Name="AceptarButton" Text="Aceptar" Clicked="AceptarButton_Clicked" Padding="16,8" TextColor="{DynamicResource PrimaryTextColor}" Margin="0"></Button>
            <Button x:Name="CancelarButton" Text="Cancelar" Clicked="CancelarButton_Clicked" Padding="16,8" TextColor="{DynamicResource SecondaryTextColor}"></Button>
        </HorizontalStackLayout>
    </Grid>
</toolkit:Popup>